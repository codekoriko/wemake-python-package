{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "internalConsole"
        },
        {
            "name": "Specific File",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sandbox.py",
            "console": "internalConsole"
        },
        {
            "name": "Debugging Current pytest file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "internalConsole",
            "args": [
                "${file}"
            ],
            "env": {
                "PYTEST_ADDOPTS": "--no-cov"
            },
        },
    ]
}
